Content-Security-Policy: 
  default-src 'self'; 
  script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; 
  style-src 'self' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; 
  img-src 'self' data: https://images.unsplash.com https://via.placeholder.com; 
  font-src 'self' https://fonts.gstatic.com; 
  connect-src 'self' https://api.example.com;  # add APIs you use
  object-src 'none'; 
  frame-ancestors 'self';  # allows your site to be embedded only in your own domain
  base-uri 'self'; 
  form-action 'self' https://yourformtarget.com;  # allow forms to submit externally
  upgrade-insecure-requests;

