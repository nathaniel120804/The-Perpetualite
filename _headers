/* 
  Full security headers for all pages
*/

/* Clickjacking / framing protection */
  X-Frame-Options: DENY

/* MIME type sniffing protection */
  X-Content-Type-Options: nosniff

/* HTTPS enforcement */
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/* Referrer policy */
  Referrer-Policy: no-referrer-when-downgrade

/* Permissions for sensitive APIs */
  Permissions-Policy: geolocation=(), microphone=(), camera=()

/* Content Security Policy: allows common external scripts, fonts, images */
  Content-Security-Policy: 
    default-src 'self'; 
    script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net 'unsafe-inline'; 
    style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; 
    img-src 'self' data: https://images.unsplash.com https://via.placeholder.com; 
    font-src 'self' https://fonts.gstatic.com; 
    connect-src 'self';

/* Cross-Origin protection */
  Cross-Origin-Embedder-Policy: require-corp
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
